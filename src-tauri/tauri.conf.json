{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RustLM",
  "version": "0.1.6",
  "identifier": "com.rustlm.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RustLM - LoL Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/RaspizDIYs/rustlm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4N0FBOTM3MjEzRTNBNDQKUldSRU9qNGhONmw2K0M3UHVaYzhtcSs0MlNXQU1SdXd5cm5TVEw0SmhtWHNsR2o3Z1hSZ09zU3oK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
